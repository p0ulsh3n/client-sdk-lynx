{
  "name": "@livekit/lynx",
  "version": "1.0.0",
  "description": "LiveKit real-time video, audio and data for Lynx (ReactLynx)",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "react-native": "src/index",
  "source": "src/index",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js"
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "livekit-lynx.podspec",
    "!lib/typescript/example",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "release": "release-it",
    "example": "yarn --cwd example",
    "pods": "cd example && pod install --project-directory=ios",
    "bootstrap": "yarn example && yarn && yarn pods"
  },
  "keywords": [
    "livekit",
    "lynx",
    "reactlynx",
    "webrtc",
    "video",
    "audio",
    "realtime",
    "tiktok"
  ],
  "author": "LiveKit contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/livekit/client-sdk-lynx.git"
  },
  "bugs": {
    "url": "https://github.com/livekit/client-sdk-lynx/issues"
  },
  "homepage": "https://github.com/livekit/client-sdk-lynx",
  "dependencies": {
    "@livekit/components-react": "^2.9.0",
    "@livekit/components-core": "^0.12.0",
    "loglevel": "^1.8.0",
    "events": "^3.3.0",
    "typed-emitter": "^2.1.0",
    "promise.allsettled": "^1.0.5",
    "array.prototype.at": "^1.1.1",
    "well-known-symbols": "^4.1.0",
    "web-streams-polyfill": "^4.1.0",
    "base64-js": "^1.5.1"
  },
  "peerDependencies": {
    "@lynx-js/react": ">=0.1.0",
    "livekit-client": "^2.15.0"
  },
  "devDependencies": {
    "@lynx-js/react": "^0.1.0",
    "@lynx-js/types": "^0.1.0",
    "livekit-client": "^2.15.0",
    "typescript": "^5.5.0",
    "eslint": "^9.0.0",
    "react-native-builder-bob": "^0.32.0"
  },
  "workspaces": [
    "example"
  ],
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  }
}
