platform :ios, '14.0'
use_frameworks!

target 'ci' do
  pod 'livekit-lynx', :path => '../..'
end

# ── Fix C++ build for Lynx / PrimJS pods ───────────────────────────────────
# Lynx's Objective-C++ files (LynxViewGroup.mm etc.) use std::result_of_t
# which is removed in strict C++17. Using GNU++17 preserves GNU extensions
# and avoids the deprecation. Also ensures <memory> is found everywhere.
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
      config.build_settings['CLANG_CXX_LIBRARY']           = 'libc++'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']   = '14.0'
    end
  end
end
