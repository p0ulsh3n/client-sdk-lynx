platform :ios, '14.0'
use_frameworks!

target 'ci' do
  pod 'livekit-lynx', :path => '../..'
end

# ── Fix C++ build + Xcode 16 compat for Lynx / PrimJS pods ─────────────────
# Problem:
#   - Lynx .cc files (worklet_utils.cc etc.) need C++17 features
#   - Lynx .m files (LynxTextLayoutManager.m) include C++ headers
#   - std::result_of_t is deprecated in C++17 — warnings must not be errors
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
      config.build_settings['CLANG_CXX_LIBRARY']           = 'libc++'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']   = '14.0'
      # Never treat warnings as errors in third-party pods
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      # Suppress deprecation + other warnings, increase error limit
      config.build_settings['OTHER_CFLAGS'] = '$(inherited) -Wno-error -Wno-deprecated-declarations -Wno-deprecated -Wno-shorten-64-to-32 -Wno-comma -Wno-unreachable-code -ferror-limit=0'
      config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -Wno-error -Wno-deprecated-declarations -Wno-deprecated -Wno-shorten-64-to-32 -ferror-limit=0'
    end

    # Force Lynx pod .m files to compile as Objective-C++ so C++ headers work
    if target.name == 'Lynx'
      target.source_build_phase.files.each do |file|
        next unless file.file_ref&.path&.end_with?('.m')
        file.settings = { 'COMPILER_FLAGS' => '-x objective-c++ -Wno-error -Wno-deprecated-declarations -Wno-deprecated' }
      end
    end
  end
end
