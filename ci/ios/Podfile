platform :ios, '14.0'
use_frameworks!

target 'ci' do
  pod 'livekit-lynx', :path => '../..'
end

# ── Fix C++ build + Xcode compat for Lynx / PrimJS pods ───────────────────
# 1. Lynx headers include <memory> → need C++ standard set
# 2. Lynx .mm/.m files may have warnings treated as errors on newer Xcode
# 3. GNU++17 for std::result_of_t compat
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
      config.build_settings['CLANG_CXX_LIBRARY']           = 'libc++'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']   = '14.0'
      # Lynx pod has internal warnings that newer Xcode may treat as errors
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      # Suppress specific warnings in third-party pods
      config.build_settings['OTHER_CFLAGS'] ||= '$(inherited)'
      config.build_settings['OTHER_CFLAGS']  += ' -Wno-error -Wno-shorten-64-to-32 -Wno-comma -Wno-unreachable-code'
    end
  end
end
