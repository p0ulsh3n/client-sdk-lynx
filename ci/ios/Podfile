platform :ios, '14.0'
use_frameworks!

target 'ci' do
  pod 'livekit-lynx', :path => '../..'
end

# ── Fix C++ build + Swift/C++ interop for Lynx pods ────────────────────────
# Lynx headers include C++ code (<memory>, <string>, etc.).
# When Swift imports the Lynx module, Clang must compile those headers
# as Objective-C++ (not Objective-C). Swift 5.9+ supports this via
# `-cxx-interoperability-mode=default` and SWIFT_OBJC_INTEROP_MODE=objcxx.
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
      config.build_settings['CLANG_CXX_LIBRARY']           = 'libc++'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']   = '14.0'

      # Never treat warnings as errors in third-party pods
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'

      # Suppress warnings in third-party pods
      config.build_settings['OTHER_CFLAGS'] = '$(inherited) -Wno-everything'
      config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -Wno-everything'

      # Enable Swift/C++ interop: tells Swift compiler to process imported
      # Clang modules as Objective-C++ so C++ headers are understood.
      config.build_settings['SWIFT_OBJC_INTEROP_MODE'] = 'objcxx'
      config.build_settings['OTHER_SWIFT_FLAGS'] = '$(inherited) -cxx-interoperability-mode=default'
    end
  end
end
